# AI Provider: "gemini" (default, free tier), "anthropic", or "demo"
AI_PROVIDER=gemini

# Gemini (free tier - 250 req/day, no credit card needed)
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (paid - fallback option)
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-key-here
SUPABASE_SERVICE_ROLE_KEY=your-key-here

# Stripe
STRIPE_SECRET_KEY=your-key-here
STRIPE_WEBHOOK_SECRET=your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-key-here
STRIPE_STARTER_PRICE_ID=your-price-id-here
STRIPE_PRO_PRICE_ID=your-price-id-here
STRIPE_AGENCY_PRICE_ID=your-price-id-here
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=your-price-id-here
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=your-price-id-here
NEXT_PUBLIC_STRIPE_AGENCY_PRICE_ID=your-price-id-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
